# ==========================================================
# Application Configuration
# ==========================================================

APP_NAME=Portfolio Backend API
APP_VERSION=1.0.0
APP_ENV=development

# ==========================================================
# AWS Configuration
# ==========================================================

AWS_REGION=ap-south-1

# ==========================================================
# S3 Configuration
# ==========================================================

S3_BUCKET_NAME=your-s3-bucket-name

# ==========================================================
# DynamoDB Configuration
# ==========================================================

DYNAMODB_CONTACT_TABLE=portfolio-contact
DYNAMODB_NOTIFICATION_TABLE=portfolio-notifications

# ==========================================================
# AWS SNS
# ==========================================================

SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:portfolio-topic

# ==========================================================
# Telegram
# ==========================================================

TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ==========================================================
# Twilio WhatsApp
# ==========================================================

TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
YOUR_WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX

# Allowed Origins
ALLOWED_ORIGINS=http://localhost:3000